---
BasedOnStyle: WebKit
AlignConsecutiveAssignments: AcrossEmptyLines
AlignTrailingComments:
  Kind: Always
BreakBeforeBraces: Allman
ColumnLimit: 120
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^("|<)trick/'
    Priority: 2
  - Regex: '^("|<)(llvm|llvm-c|clang|clang-c)/'
    Priority: 3
  - Regex: '^("|<)(gtest|gmock)/'
    Priority: 5
  - Regex: "^<.*>"
    Priority: 4
  - Regex: ".*"
    Priority: 1
...
